<?xml version="1.0"?>
<!--
  poseEstimation3D — stream an RGB topic to a remote sam_3dbody_net server and
  republish the skeleton as TF + Float32MultiArray.

  On the GPU box, start the server first (note: --jlocal for the oriented TF tree):
      ./build/sam_3dbody_net --server --port 8080 --jlocal
-->
<launch>
  <node name="poseEstimation3D" pkg="poseEstimation3D" type="poseEstimation3D" output="screen" respawn="true">

    <!-- Where the GPU pose server is -->
    <param name="serverHost"        value="127.0.0.1" />
    <param name="serverPort"        value="8080" />
    <param name="socketTimeout"     value="10" />
    <param name="jpegQuality"       value="80" />

    <!-- Robot camera image topic (sensor_msgs/Image, BGR/RGB) -->
    <param name="fromRGBTopic"      value="/camera/rgb/image_raw" />

    <!-- TF frames -->
    <param name="tfRoot"            value="map" />
    <param name="cameraFrame"       value="poseEstimation3DCamera" />
    <param name="personFramePrefix" value="p" />          <!-- p0/&lt;joint&gt;, p1/&lt;joint&gt; -->
    <param name="publishCameraTF"   value="1" />

    <!-- 0 = full oriented tree from JLOCAL (server needs --jlocal)
         1 = positions-only frames from KP3D (server needs the body model) -->
    <param name="useSimple3DPointTF" value="0" />

    <!-- Camera placement in tfRoot, and the camera-optical -> ROS (REP-103)
         orientation, in DEGREES.  Tune these three if the skeleton is rotated. -->
    <param name="cameraXPosition"   value="0.0" />
    <param name="cameraYPosition"   value="0.0" />
    <param name="cameraZPosition"   value="0.0" />
    <param name="cameraRoll"        value="-90.0" />
    <param name="cameraPitch"       value="0.0" />
    <param name="cameraYaw"         value="-90.0" />
  </node>
</launch>
